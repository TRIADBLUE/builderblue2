# Database
DATABASE_URL=postgresql://user:password@host:5432/builderblue2

# JWT Secrets — generate long random strings (64+ characters recommended)
ACCESS_TOKEN_SECRET=generate-a-long-random-string
REFRESH_TOKEN_SECRET=generate-a-different-long-random-string

# Owner — this email auto-elevates to 'owner' role on login/register
OWNER_EMAIL=dean@triadblue.com

# Application
BASE_URL=http://localhost:5000
PORT=5000

# Resend (email service)
RESEND_API_KEY=your-resend-api-key

# HostsBlue SSO — shared HMAC secret
HOSTSBLUE_SSO_SECRET=shared-secret-with-hostsblue
