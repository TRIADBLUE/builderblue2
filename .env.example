# Database
DATABASE_URL=postgresql://user:password@host:5432/builderblue2

# JWT Secrets — generate long random strings (64+ characters recommended)
ACCESS_TOKEN_SECRET=generate-a-long-random-string
REFRESH_TOKEN_SECRET=generate-a-different-long-random-string

# Owner — this email auto-elevates to 'owner' role on login/register
OWNER_EMAIL=dean@triadblue.com

# Application
BASE_URL=http://localhost:5000
PORT=5000

# Resend (email service)
RESEND_API_KEY=your-resend-api-key

# HostsBlue SSO — shared HMAC secret
HOSTSBLUE_SSO_SECRET=shared-secret-with-hostsblue

# AI Providers
ANTHROPIC_API_KEY=your-anthropic-api-key
DEEPSEEK_API_KEY=your-deepseek-api-key
GEMINI_API_KEY=your-gemini-api-key
KIMI_API_KEY=your-kimi-api-key
GROQ_API_KEY=your_groq_api_key_here


# Encryption — generate with: openssl rand -base64 32
ENCRYPTION_KEY=generate-32-byte-base64-string

# GitHub
GITHUB_TOKEN=your-github-personal-access-token
